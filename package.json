{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "pi-provider-koji",
  "version": "0.8.0",
  "description": "Pi agent extension for koji local AI server auto-discovery and model configuration",
  "type": "module",
  "main": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "files": [
    "src"
  ],
  "pi": {
    "extensions": [
      "./src/index.ts"
    ]
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix"
  },
  "keywords": [
    "pi-package",
    "pi",
    "pi-agent",
    "koji",
    "extension",
    "local-llm",
    "openai-compatible",
    "auto-discovery"
  ],
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": "*"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/danielcherubini/pi-provider-koji.git"
  },
  "homepage": "https://github.com/danielcherubini/pi-provider-koji#readme",
  "bugs": {
    "url": "https://github.com/danielcherubini/pi-provider-koji/issues"
  },
  "author": "Daniel Cherubini",
  "license": "MIT",
  "devDependencies": {
    "@mariozechner/pi-coding-agent": "*",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^4.0.0",
    "typescript": "^5.9.0",
    "vitest": "^4.0.0"
  }
}
